# Copy to .env and adjust. Never commit .env with production secrets.

# --- API auth (required in production; matches X-API-Key on requests) ---
# Injected into /dashboard at serve time (placeholder in dashboard/index.html — do not paste real keys there).
#API_KEY=

# --- Optional: FMCSA mobile API web key ---
# If unset, carrier verification still uses the VerifyCarrier fallback when possible.
# FMCSA_WEBKEY=

# --- Optional: SQLite path ---
# Default is data/carrier_sales.db (relative to process cwd). On Railway with a volume, set e.g. /app/data/carrier_sales.db.
# DB_PATH=
