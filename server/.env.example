HAPPYROBOT_API_KEY=your_api_key
WORKFLOW_ID=your_workflow_id
PORT=3001

# Must match where the workflow is published (HappyRobot UI). Default in code is production.
# development | staging | production
HAPPYROBOT_ENVIRONMENT=production

# Deployed voice UI only: comma-separated https origins (no trailing slashes). Localhost is always allowed.
# VOICE_CLIENT_ORIGINS=https://your-voice-client.vercel.app
